# Optional: get live YouTube video results on the Resources page.
# Create a key at https://console.cloud.google.com/apis/credentials (YouTube Data API v3).
# In Vercel: Project → Settings → Environment Variables → add YOUTUBE_API_KEY.
YOUTUBE_API_KEY=

# Auth (NextAuth with Google). Required for "Sign in with Google".
# Generate secret: npx auth secret
# Google OAuth: https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID).
# Authorized redirect URI: https://your-domain.com/api/auth/callback/google (and http://localhost:3000/api/auth/callback/google for dev)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
