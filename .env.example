# Optional: get live YouTube video results on the Resources page.
# Create a key at https://console.cloud.google.com/apis/credentials (YouTube Data API v3).
# In Vercel: Project → Settings → Environment Variables → add YOUTUBE_API_KEY.
YOUTUBE_API_KEY=

# Auth (NextAuth with Google). Required for "Sign in with Google".
# Generate secret: npx auth secret
# Google OAuth: https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID).
# 1) Authorised JavaScript origins: https://your-domain.vercel.app and http://localhost:3005
# 2) Authorised redirect URIs: https://your-domain.vercel.app/api/auth/callback/google and http://localhost:3005/api/auth/callback/google
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Production only (Vercel): set to your main deployment URL so callbacks work, e.g. https://fitness-tracker-xlzi.vercel.app
AUTH_URL=
